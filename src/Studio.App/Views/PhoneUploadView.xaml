<UserControl x:Class="Studio.App.Views.PhoneUploadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}" Text="Photos depuis un téléphone"/>

        <Border Grid.Row="1" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="24">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Style="{StaticResource Hint}" TextAlignment="Center" Margin="0,0,0,16"
                           Text="Le client scanne ce code avec l'appareil photo de son téléphone (même WiFi que le magasin), puis choisit ses photos."/>
                <Border Background="White" Padding="16" CornerRadius="12" HorizontalAlignment="Center">
                    <Image x:Name="QrImage" Width="320" Height="320"/>
                </Border>
                <TextBlock x:Name="UrlText" FontSize="22" FontWeight="SemiBold" TextAlignment="Center"
                           Margin="0,12,0,0" Foreground="{StaticResource TextBrush}"/>
                <TextBlock x:Name="CountText" FontSize="26" FontWeight="Bold" TextAlignment="Center"
                           Margin="0,24,0,0" Foreground="{StaticResource OkBrush}"
                           Text="En attente de photos…"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16" Margin="0,16,0,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left" Style="{StaticResource Hint}" VerticalAlignment="Center"
                           Text="Les photos apparaissent ici au fur et à mesure."/>
                <Button x:Name="OpenButton" DockPanel.Dock="Right" Style="{StaticResource BigButton}"
                        HorizontalAlignment="Right" IsEnabled="False" Click="OnOpenPhotos">
                    ➜  Ouvrir les photos reçues
                </Button>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
