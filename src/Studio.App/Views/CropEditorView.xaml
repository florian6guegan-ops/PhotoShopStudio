<UserControl x:Class="Studio.App.Views.CropEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <TextBlock x:Name="TitleText" DockPanel.Dock="Left" Style="{StaticResource PageTitle}"/>
            <TextBlock x:Name="HintText" DockPanel.Dock="Right" Style="{StaticResource Hint}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"
                       Text="Faites glisser le cadre, zoomez à la molette ou au pincement"/>
        </DockPanel>

        <!-- Scène : photo + voile sombre hors recadrage -->
        <Border Grid.Row="1" Background="#263238" CornerRadius="12" ClipToBounds="True">
            <Grid x:Name="Stage" Background="Transparent"
                  MouseLeftButtonDown="OnStageMouseDown" MouseLeftButtonUp="OnStageMouseUp"
                  MouseMove="OnStageMouseMove" MouseWheel="OnStageWheel"
                  IsManipulationEnabled="True"
                  ManipulationStarting="OnManipulationStarting"
                  ManipulationDelta="OnManipulationDelta"
                  SizeChanged="OnStageSizeChanged">
                <Image x:Name="Photo" Stretch="Uniform" Margin="0"/>
                <Canvas x:Name="Overlay" IsHitTestVisible="False">
                    <Path x:Name="Shade" Fill="#A6000000"/>
                    <Rectangle x:Name="CropBorder" Stroke="White" StrokeThickness="3"/>
                </Canvas>
                <TextBlock x:Name="FitMessage" Visibility="Collapsed"
                           Foreground="White" FontSize="24" FontWeight="SemiBold"
                           HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,18"
                           Text="La photo entière sera imprimée, avec des marges blanches si besoin."/>
            </Grid>
        </Border>

        <!-- Barre d'action -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16" Margin="0,16,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button Style="{StaticResource FlatButton}" MinWidth="150" Click="OnRotate">⟳ Pivoter</Button>
                    <Button x:Name="FitToggle" Style="{StaticResource FlatButton}" MinWidth="180"
                            Margin="12,0,0,0" Click="OnToggleFit"/>
                    <Button Style="{StaticResource FlatButton}" MinWidth="90" Margin="24,0,0,0"
                            FontSize="30" Click="OnZoomOut">−</Button>
                    <TextBlock Text="Zoom" Style="{StaticResource Hint}" VerticalAlignment="Center" Margin="12,0"/>
                    <Button Style="{StaticResource FlatButton}" MinWidth="90" FontSize="30" Click="OnZoomIn">+</Button>
                    <Button Style="{StaticResource FlatButton}" MinWidth="170" Margin="24,0,0,0"
                            Click="OnReset">Réinitialiser</Button>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource FlatButton}" MinWidth="150" Click="OnCancel">Annuler</Button>
                    <Button Style="{StaticResource BigButton}" Margin="12,0,0,0" Click="OnApply">✓ Valider</Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
