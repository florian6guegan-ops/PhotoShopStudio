<UserControl x:Class="Studio.App.Views.PhotoGridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <TextBlock DockPanel.Dock="Left" Style="{StaticResource PageTitle}"
                       Text="Touchez les photos à imprimer"/>
            <TextBlock x:Name="CountText" DockPanel.Dock="Right" Style="{StaticResource Hint}"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </DockPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="PhotosGrid">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Height="200" Margin="8" CornerRadius="10"
                                Background="{StaticResource CardBrush}"
                                BorderThickness="4"
                                BorderBrush="{Binding BorderBrush}"
                                MouseLeftButtonUp="OnPhotoClicked" Tag="{Binding}">
                            <Grid>
                                <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="6"/>
                                <Border Background="{StaticResource OkBrush}" CornerRadius="8"
                                        Width="40" Height="40" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="6" Visibility="{Binding CheckVisibility}">
                                    <TextBlock Text="✓" Foreground="White" FontSize="24" FontWeight="Bold"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="{Binding Name}" FontSize="13" Foreground="{StaticResource MutedBrush}"
                                           VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" Margin="8,0,8,4"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Barre d'action : produit, quantité, impression -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16" Margin="0,16,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Produit :" Style="{StaticResource Hint}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="ProductCombo" MinWidth="320" FontSize="22" Padding="10,8"
                              DisplayMemberPath="Label" VerticalAlignment="Center"/>
                    <TextBlock Text="Quantité :" Style="{StaticResource Hint}" VerticalAlignment="Center" Margin="24,0,8,0"/>
                    <Button Style="{StaticResource FlatButton}" MinWidth="56" MinHeight="56" Padding="0"
                            FontSize="26" Click="OnQuantityMinus">−</Button>
                    <TextBlock x:Name="QuantityText" Text="1" FontSize="26" FontWeight="Bold"
                               VerticalAlignment="Center" MinWidth="48" TextAlignment="Center"/>
                    <Button Style="{StaticResource FlatButton}" MinWidth="56" MinHeight="56" Padding="0"
                            FontSize="26" Click="OnQuantityPlus">+</Button>
                </StackPanel>
                <Button x:Name="PrintButton" DockPanel.Dock="Right" HorizontalAlignment="Right"
                        Style="{StaticResource BigButton}" Click="OnPrint" IsEnabled="False">
                    🖨  Imprimer
                </Button>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
