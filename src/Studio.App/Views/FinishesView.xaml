<UserControl x:Class="Studio.App.Views.FinishesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="TitleText" Style="{StaticResource PageTitle}"/>

        <TextBlock Grid.Row="1" Style="{StaticResource Hint}" Margin="0,0,0,16" TextWrapping="Wrap"
                   Text="Une finition = un jeu de réglages du pilote, enregistré sous un nom. Saisissez le nom (Brillant, Mat, Lustré…), cliquez sur « Capturer » : le dialogue du pilote s'ouvre, choisissez-y la finition, validez. L'opérateur pourra ensuite la choisir au moment d'imprimer."/>

        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Nom :" Style="{StaticResource Hint}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBox x:Name="NameBox" MinWidth="260" FontSize="20" Padding="10,8" VerticalAlignment="Center"/>
                <Button Style="{StaticResource BigButton}" Margin="16,0,0,0" MinHeight="52" MinWidth="260"
                        Click="OnCapture">⚙ Capturer les réglages du pilote</Button>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="FinishesList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16" Margin="0,0,0,10">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Style="{StaticResource FlatButton}" MinHeight="48" MinWidth="150"
                                            FontSize="18" Padding="12,6" ToolTip="Rouvrir le dialogue du pilote"
                                            Click="OnRecapture" Tag="{Binding}">⚙ Recapturer</Button>
                                    <Button Style="{StaticResource FlatButton}" Margin="8,0,0,0" MinHeight="48"
                                            MinWidth="120" FontSize="18" Padding="12,6"
                                            Click="OnDelete" Tag="{Binding}">🗑 Retirer</Button>
                                </StackPanel>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock FontSize="22" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextBrush}" Text="{Binding Name}"/>
                                    <TextBlock FontSize="17" Foreground="{StaticResource MutedBrush}"
                                               Text="{Binding File}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <TextBlock x:Name="ErrorText" Foreground="#E53935" FontSize="17"
                       VerticalAlignment="Center" Margin="0,0,16,0" TextWrapping="Wrap"/>
            <Button Style="{StaticResource BigButton}" MinWidth="160" Click="OnClose">Terminé</Button>
        </StackPanel>
    </Grid>
</UserControl>
