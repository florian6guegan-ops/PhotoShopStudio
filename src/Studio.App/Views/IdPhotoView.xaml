<UserControl x:Class="Studio.App.Views.IdPhotoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <TextBlock DockPanel.Dock="Left" Style="{StaticResource PageTitle}" Text="Photo d'identité 35×45"/>
            <TextBlock DockPanel.Dock="Right" Style="{StaticResource Hint}" HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Text="Le cadrage se règle comme une photo : glisser, molette, pincement"/>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Bande de choix de la photo -->
            <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="8" Margin="0,0,12,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="PhotoStrip">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="4" CornerRadius="8" BorderThickness="4"
                                        BorderBrush="{Binding BorderBrush}" Background="#F0F2F4"
                                        MouseLeftButtonUp="OnStripPhotoClicked" Tag="{Binding}">
                                    <Grid Height="150">
                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="4"/>
                                        <TextBlock Text="{Binding Name}" FontSize="11" Foreground="{StaticResource MutedBrush}"
                                                   VerticalAlignment="Bottom" HorizontalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis" Margin="4,0,4,2"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <!-- Scène de cadrage -->
            <Border Grid.Column="1" Background="#263238" CornerRadius="12" ClipToBounds="True">
                <Grid x:Name="Stage" Background="Transparent"
                      MouseLeftButtonDown="OnStageMouseDown" MouseLeftButtonUp="OnStageMouseUp"
                      MouseMove="OnStageMouseMove" MouseWheel="OnStageWheel"
                      IsManipulationEnabled="True"
                      ManipulationStarting="OnManipulationStarting"
                      ManipulationDelta="OnManipulationDelta"
                      SizeChanged="OnStageSizeChanged">
                    <Image x:Name="Photo" Stretch="Uniform"/>
                    <Canvas x:Name="Overlay" IsHitTestVisible="False">
                        <Path x:Name="Shade" Fill="#A6000000"/>
                        <Rectangle x:Name="CropBorder" StrokeThickness="4"/>
                        <Line x:Name="CrownLine" StrokeThickness="1.5" StrokeDashArray="4 3"/>
                        <Line x:Name="ChinMinLine" StrokeThickness="1.5" StrokeDashArray="4 3"/>
                        <Line x:Name="ChinMaxLine" StrokeThickness="1.5" StrokeDashArray="4 3"/>
                    </Canvas>
                    <TextBlock x:Name="EmptyText" Foreground="White" FontSize="24" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Text="Choisissez une photo à gauche"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Barre d'action -->
        <Border Grid.Row="2" Background="{StaticResource CardBrush}" CornerRadius="12" Padding="16" Margin="0,16,0,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <ComboBox x:Name="ProductCombo" MinWidth="300" FontSize="20" Padding="10,8"
                              DisplayMemberPath="Label" VerticalAlignment="Center"/>
                    <TextBlock Text="Planches :" Style="{StaticResource Hint}" VerticalAlignment="Center" Margin="20,0,8,0"/>
                    <Button Style="{StaticResource FlatButton}" MinWidth="52" MinHeight="52" Padding="0"
                            FontSize="24" Click="OnQuantityMinus">−</Button>
                    <TextBlock x:Name="QuantityText" Text="1" FontSize="24" FontWeight="Bold"
                               VerticalAlignment="Center" MinWidth="44" TextAlignment="Center"/>
                    <Button Style="{StaticResource FlatButton}" MinWidth="52" MinHeight="52" Padding="0"
                            FontSize="24" Click="OnQuantityPlus">+</Button>
                    <CheckBox x:Name="GrayscaleCheck" VerticalAlignment="Center" Margin="24,0,0,0"
                              Checked="OnGrayscaleChanged" Unchecked="OnGrayscaleChanged">
                        <TextBlock Text="Noir et blanc" FontSize="18"/>
                    </CheckBox>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource FlatButton}" MinWidth="130" Click="OnRedetect"
                            ToolTip="Refaire le cadrage automatique">↻ Auto</Button>
                    <Button x:Name="PrintButton" Style="{StaticResource BigButton}" Margin="12,0,0,0"
                            Click="OnPrint" IsEnabled="False">🖨  Imprimer la planche</Button>
                </StackPanel>
                <TextBlock x:Name="ComplianceText" FontSize="19" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="24,0" TextWrapping="Wrap"/>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
