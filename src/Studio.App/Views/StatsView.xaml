<UserControl x:Class="Studio.App.Views.StatsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}" Text="Statistiques (30 derniers jours)"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource CardBrush}" CornerRadius="12"
                    Padding="20" Margin="0,0,8,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12"
                               Foreground="{StaticResource TextBrush}" Text="Par jour"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DaysList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,4">
                                        <TextBlock DockPanel.Dock="Right" FontSize="19" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}" Text="{Binding Revenue}"/>
                                        <TextBlock FontSize="19" Foreground="{StaticResource TextBrush}"
                                                   Text="{Binding Label}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource CardBrush}" CornerRadius="12"
                    Padding="20" Margin="8,0,0,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,12"
                               Foreground="{StaticResource TextBrush}" Text="Par produit"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="ProductsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,4">
                                        <TextBlock DockPanel.Dock="Right" FontSize="19" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}" Text="{Binding Revenue}"/>
                                        <TextBlock FontSize="19" Foreground="{StaticResource TextBrush}"
                                                   Text="{Binding Label}"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
