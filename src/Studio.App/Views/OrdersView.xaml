<UserControl x:Class="Studio.App.Views.OrdersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}" Text="Commandes récentes"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="EmptyText" Style="{StaticResource Hint}"
                           Text="Aucune commande ces derniers jours." Visibility="Collapsed"/>
                <ItemsControl x:Name="OrdersList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource CardBrush}" CornerRadius="12"
                                    Padding="16" Margin="0,0,0,12">
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" FontSize="24" FontWeight="Bold"
                                                   Foreground="{StaticResource TextBrush}" Text="{Binding Header}"/>
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                                            <Button Style="{StaticResource FlatButton}" MinHeight="44" MinWidth="120"
                                                    FontSize="17" Padding="12,4" Margin="0,0,16,0"
                                                    ToolTip="Imprimer le ticket de caisse"
                                                    Click="OnPrintTicket" Tag="{Binding}">🧾 Ticket</Button>
                                            <TextBlock FontSize="22" VerticalAlignment="Center"
                                                       Foreground="{Binding StatusBrush}" FontWeight="SemiBold"
                                                       Text="{Binding StatusText}"/>
                                        </StackPanel>
                                    </DockPanel>
                                    <ItemsControl ItemsSource="{Binding Envelopes}" Margin="0,10,0,0">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <DockPanel Margin="0,4">
                                                    <Button DockPanel.Dock="Right" Style="{StaticResource FlatButton}"
                                                            MinHeight="48" MinWidth="180" FontSize="18" Padding="16,6"
                                                            Click="OnReprint" Tag="{Binding}">
                                                        🖨  Réimprimer
                                                    </Button>
                                                    <TextBlock FontSize="19" VerticalAlignment="Center"
                                                               Foreground="{StaticResource MutedBrush}"
                                                               Text="{Binding Label}" TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
